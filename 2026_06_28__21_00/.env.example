# Copie para .env e ajuste se necessário:  cp .env.example .env
# Nenhum segredo aqui. Tudo roda local; nenhuma API paga é necessária.

OLLAMA_HOST=http://localhost:11434

# Geração (usada pelo reranker por LLM e pela avaliação faithfulness).
GEN_MODEL=llama3.2:3b

# Embeddings de retrieval (separado do LLM gerador). Apache-2.0.
EMBED_MODEL=nomic-embed-text

# Modo MOCK: 1 = não chama o Ollama (embeddings por hashing + LLM canned). Determinístico,
# para CI/offline. NÃO substitui a execução real. Os scripts caem para MOCK se o Ollama
# não responder. Deixe 0 para usar modelo de verdade.
USE_MOCK=0

# OPCIONAL — cross-encoder real (reranker "cross"), só com requirements-extra.txt.
CROSS_ENCODER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
