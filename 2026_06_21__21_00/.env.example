# Copie para .env e ajuste se necessário:  cp .env.example .env
# Nenhum segredo aqui. Tudo roda local; nenhuma API paga é necessária.

# Endereço do servidor Ollama (runtime de modelos locais).
OLLAMA_HOST=http://localhost:11434

# Modelo de GERAÇÃO. Padrão de qualidade/tamanho em CPU.
# Alternativas: llama3.2:1b (mais leve, ~1.3GB), qwen2.5:1.5b (licença Apache-2.0).
# ATENÇÃO didática: llama3.2 é "open weights", NÃO "open source" (Llama Community
# License, com restrições). Ver docs/decisoes-e-limitacoes.md.
GEN_MODEL=llama3.2:3b

# Modelo de EMBEDDINGS de retrieval (separado do LLM gerador).
# nomic-embed-text: Apache-2.0, ~274MB, 768 dimensões, rápido em CPU.
EMBED_MODEL=nomic-embed-text

# Modo MOCK: 1 = não chama o Ollama; usa embeddings determinísticos por hashing e
# um "LLM" canned. Serve APENAS para validar o pipeline e rodar testes sem baixar
# modelo. NÃO substitui a execução real com modelo local.
# Deixe 0 para usar o modelo de verdade; os scripts caem para 1 se o Ollama não responder.
USE_MOCK=0
